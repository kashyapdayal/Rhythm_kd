+internal fun chromahub.rhythm.app.infrastructure.audio.usb.UsbConnectionOrchestrator.EnumeratedDevice.toDeviceCapabilities(): chromahub.rhythm.app.infrastructure.audio.siphon.SiphonDeviceCapabilities {
