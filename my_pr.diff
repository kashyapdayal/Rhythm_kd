diff --git a/app/src/main/java/chromahub/rhythm/app/infrastructure/audio/siphon/SiphonAudioFormat.kt b/app/src/main/java/chromahub/rhythm/app/infrastructure/audio/siphon/SiphonAudioFormat.kt
